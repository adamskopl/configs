# append to the end of the original config

set $RESOLUTION_LEFT 1920x1080
set $RESOLUTION_RIGHT 1280x800
# focus_follows_mouse no

set $DISPLAY_LEFT HDMI-3
set $DISPLAY_RIGHT LVDS-1
set $WALLPAPER_FILE ~/Pictures/wallpapers/city3.png

exec nm-applet
exec_always feh --bg-fill $WALLPAPER_FILE # --bg-center --bg-fill --bg-max --bg-scale --bg-tile
exec ~/exec-terminator.sh # update-manager -d, other

exec xrandr --output $DISPLAY_LEFT --primary --left-of $DISPLAY_RIGHT --mode $RESOLUTION_LEFT --output $DISPLAY_RIGHT --mode $RESOLUTION_RIGHT

exec --no-startup-id compton --config ~/.config/i3/compton.conf
exec alarm-clock-applet

# --- BINDSYM
bindsym Control+$mod+l exec i3lock -t -i $WALLPAPER_FILE
bindsym $mod+q sticky toggle
bindsym $mod+plus exec amixer sset Master 5%+
bindsym $mod+minus exec amixer sset Master 5%-

bindsym $mod+F1 exec amixer -D pulse set Master 1+ toggle
bindsym $mod+F2 exec amixer sset Master 5%-
bindsym $mod+F3 exec amixer sset Master 5%+

bindsym $mod+backslash exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.PlayPause"
bindsym $mod+bracketleft exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Previous"
bindsym $mod+bracketright exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Next"

bindsym $mod+F5 exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.PlayPause"
bindsym $mod+F6 exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Stop"
bindsym $mod+F7 exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Previous"
bindsym $mod+F8 exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Next"

workspace 1 output $DISPLAY_LEFT
workspace 2 output $DISPLAY_LEFT
workspace 3 output $DISPLAY_LEFT
workspace 4 output $DISPLAY_LEFT
workspace 5 output $DISPLAY_LEFT

workspace 6 output $DISPLAY_RIGHT
workspace 7 output $DISPLAY_RIGHT
workspace 8 output $DISPLAY_RIGHT
workspace 9 output $DISPLAY_RIGHT
workspace 10 output $DISPLAY_RIGHT

exec_always setxkbmap -option ctrl:swapcaps
exec_always setxkbmap pl
