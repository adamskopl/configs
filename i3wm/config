# append to the end of the original config

set $screen_left VGA1
set $screen_right HDMI2
set $wallpaper_file ~/Pictures/games/green_fantasy_art_cyberpunk_artwork_fan_1920x1080_71932.jpg

exec xrandr --auto --output $screen_right --mode 1920x1080 --right-of $screen_left
exec setxkbmap -option ctrl:swapcaps
exec compton &
exec nm-applet

exec_always feh --bg-scale $wallpaper_file

bindsym Control+$mod+l exec i3lock

# ATTENTION: comment out standard workspace switch bindings
bindsym $mod+1 workspace 1, workspace 5
bindsym $mod+2 workspace 2, workspace 6
bindsym $mod+3 workspace 3, workspace 7
bindsym $mod+4 workspace 4, workspace 8
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8

workspace 1 output $screen_left
workspace 2 output $screen_left
workspace 3 output $screen_left
workspace 4 output $screen_left
workspace 5 output $screen_right
workspace 6 output $screen_right
workspace 7 output $screen_right
workspace 8 output $screen_right